# =============================================================================
# steam.lst — Steam game installs, caches, and Proton compat state
# =============================================================================
# Kept: appmanifest_*.acf, libraryfolders.vdf, userdata/ (local saves &
# per-user config), Steam client config — enough to reinstall the same set of
# games and pick up where you left off after a restore.
#
# Excluded: actual game payloads (common/), in-flight downloads, shader caches,
# workshop content, Proton compatdata (regenerated on first launch), and
# Steam-side caches/logs.

# --- Primary library: ~/.local/share/Steam/steamapps ---
home/*/.local/share/Steam/steamapps/common
home/*/.local/share/Steam/steamapps/downloading
home/*/.local/share/Steam/steamapps/shadercache
home/*/.local/share/Steam/steamapps/workshop/content
home/*/.local/share/Steam/steamapps/compatdata
home/*/.local/share/Steam/steamapps/temp
home/*/.local/share/Steam/steamapps/music

# --- Steam client caches and ephemeral state ---
home/*/.local/share/Steam/depotcache
home/*/.local/share/Steam/appcache
home/*/.local/share/Steam/package
home/*/.local/share/Steam/logs
home/*/.local/share/Steam/dumps
