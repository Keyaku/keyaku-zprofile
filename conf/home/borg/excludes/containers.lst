# =============================================================================
# containers.lst — Container image layers and runtime state
# =============================================================================
# Excludes Podman/Docker overlay image layers and ephemeral runtime state.
# Persistent data (volumes, secrets, network config) is intentionally kept.

# --- Rootful Docker — image layers, metadata, runtime state (volumes kept) ---
var/lib/docker/overlay2
var/lib/docker/image
var/lib/docker/containers
var/lib/docker/builder
var/lib/docker/buildkit
var/lib/docker/network
var/lib/docker/plugins
var/lib/docker/runtimes
var/lib/docker/swarm
var/lib/docker/tmp
var/lib/docker/trust

# --- containerd — snapshots and content store; no native volume concept ---
var/lib/containerd

# --- Docker rootless (per-user) ---

# Overlay image layers — repullable
home/*/.local/share/docker/overlay2

# Image and layer index metadata — rebuilt on pull
home/*/.local/share/docker/image

# Per-container runtime dirs — recreated on container start
home/*/.local/share/docker/containers

# BuildKit cache — rebuildable
home/*/.local/share/docker/buildkit

# Temp files
home/*/.local/share/docker/tmp


# --- Rootful Podman — image layers, runtime state (volumes kept) ---
var/lib/containers/storage/overlay
var/lib/containers/storage/overlay-layers
var/lib/containers/storage/overlay-images
var/lib/containers/storage/overlay-containers
var/lib/containers/storage/libpod

# --- Podman rootless (per-user) ---

# Overlay image layers — repullable
home/*/.local/share/containers/storage/overlay

# Layer and image index metadata — rebuilt on pull
home/*/.local/share/containers/storage/overlay-layers
home/*/.local/share/containers/storage/overlay-images

# Per-container overlay working dirs — recreated on container start
home/*/.local/share/containers/storage/overlay-containers

# libpod runtime state (container records, locks) — regenerated by Podman
home/*/.local/share/containers/storage/libpod
